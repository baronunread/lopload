# Points the scenario suite at a REAL provider instead of the local MinIO:
#
#   cp .env.remote.example .env.remote   # then fill it in
#   bun run test:remote
#
# It runs the same tests/scenarios/* the local suite does — the real UI, the real
# engine, the real signing — just against real storage. MinIO is an excellent S3
# impersonator right up until it isn't, and the bugs that live in that gap
# (checksum middleware, ETag formats, redirect behaviour) are exactly the ones a
# local-only suite can never catch. This is the run that catches them.
#
# Safety: everything the run touches lives under `lopload-test/<run-id>/`, and
# that prefix is the only thing it is capable of deleting — see
# tests/support/bucketProbe.ts. It still writes real objects and bills real
# requests, so point it at a bucket you'd be relaxed about.
#
# The LOPLOAD_TEST_REMOTE=1 flag is deliberate: credentials alone won't redirect
# a routine `bun test` at your production bucket.

LOPLOAD_TEST_REMOTE=1
LOPLOAD_TEST_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
LOPLOAD_TEST_BUCKET=my-test-bucket
LOPLOAD_TEST_ACCESS_KEY=
LOPLOAD_TEST_SECRET_KEY=
# R2 wants "auto"; S3 wants a real region like us-east-1.
LOPLOAD_TEST_REGION=auto
