{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:default",
    "sql:allow-execute",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://**" }, { "url": "http://**" }]
    },
    "fs:default",
    "fs:read-all",
    "fs:read-dirs",
    "fs:read-meta",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "/Volumes/**" },
        { "path": "/Users/**" },
        { "path": "/mnt/**" },
        { "path": "/media/**" },
        { "path": "/tmp/**" },
        { "path": "/private/**" }
      ]
    },
    "dialog:default",
    "notification:default",
    "store:default"
  ]
}
