{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-open-path",
    "opener:allow-reveal-item-in-dir",
    "sql:default",
    "sql:allow-execute",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://*:*" }, { "url": "http://*:*" }]
    },
    "fs:default",
    "fs:read-all",
    "fs:read-dirs",
    "fs:read-meta",
    "fs:write-all",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$APPLOGDIR/**" },
        { "path": "/Volumes/**" },
        { "path": "/Users/**" },
        { "path": "/mnt/**" },
        { "path": "/media/**" },
        { "path": "/tmp/**" },
        { "path": "/private/**" },
        { "path": "/var/folders/**" }
      ]
    },
    "dialog:default",
    "notification:default",
    "store:default",
    "updater:default",
    "process:default"
  ]
}
