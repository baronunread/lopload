<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required by Tauri webview (JIT compilation, library loading). -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Network access for S3 connections. -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Keychain access. No explicit entitlement is needed for a hardened,
         non-sandboxed app to read/write its own keychain items, but this
         group declaration ensures the app's Keychain items are scoped to
         the bundle identifier. -->
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)com.lopload.app</string>
    </array>
</dict>
</plist>
